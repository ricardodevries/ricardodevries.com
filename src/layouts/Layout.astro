---
import "../assets/css/main.scss";

import Footer from "@/components/Footer.astro";
import Analytics from "@/components/Analytics.astro";

import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  metaDescription?: string;
  canonicalURL?: string;
  keywords?: string[];
  pubDatetime?: Date;
  modDatetime?: Date | null;
  is404?: boolean;
  slug?: string;
}

const {
  title,
  description,
  metaDescription,
  pubDatetime,
  modDatetime,
  keywords,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = Astro.props;

const params = new URLSearchParams({
  title: title || "",
  description: description || "",
});
const ogImg = new URL("og.png?" + params, Astro.url.origin).href;

// Add the title and description to the social image url
const siteName = Astro.site?.hostname;
const prefixedTitle = title ? `${title} | ${siteName}` : siteName;
const desc = metaDescription ?? description ?? null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Meta for seo and so on -->
    <meta name="title" content={prefixedTitle} />
    {desc && <meta name="description" content={desc} />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={prefixedTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImg} />
    {desc && <meta property="og:description" content={desc} />}
    <meta property="og:url" content={canonicalURL} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }
    {
      keywords &&
        keywords.length > 0 &&
        keywords.map((keyword) => <meta name="article:tag" content={keyword} />)
    }

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={prefixedTitle} />
    {desc && <meta property="twitter:description" content={desc} />}
    <meta property="twitter:image" content={ogImg} />

    <Font cssVariable="--font-ibm-plex-sans" preload />
    <Font cssVariable="--font-mono-lisa" preload />

    <title>{prefixedTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="page">
      <slot />
      <Footer />
    </div>
    <Analytics />
  </body>
</html>
