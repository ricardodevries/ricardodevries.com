---
import spriteMarkup from "@dev.icons/core/sprite?raw";
import { getIcon, type IconRecord } from "@dev.icons/core";
import { Check, Copy } from "@lucide/astro";

interface Props {
  code: string;
  lang?: string;
  langName?: string;
  title?: string | null;
}

interface DevIconSymbol {
  content: string;
  viewBox: string;
}

const { code, lang = "", langName, title }: Props = Astro.props;

const preferredIconSlugs: Record<string, string> = {
  astro: "astro-icon",
  bash: "bash-icon",
  css: "css-3-icon",
  docker: "docker-icon",
  dockerfile: "docker-icon",
  env: "env",
  html: "html-5",
  js: "javascript",
  jsx: "react",
  md: "markdown",
  mjs: "javascript",
  node: "nodejs-icon",
  nodejs: "nodejs-icon",
  "node-js": "nodejs-icon",
  sh: "bash-icon",
  shell: "bash-icon",
  sql: "postgresql",
  svelte: "svelte-icon",
  ts: "typescript-icon",
  tsx: "react",
  typescript: "typescript-icon",
  yml: "yaml",
};

const normalizeIconSlug = (value: string): string =>
  value
    .trim()
    .toLowerCase()
    .replace(/^@/, "")
    .replace(/^\./, "")
    .replace(/\+\+/g, "-plusplus")
    .replace(/\+/g, "-plus")
    .replace(/#/g, "-sharp")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const getExistingIconSlug = (candidate: string): string | null => {
  const preferredCandidate = preferredIconSlugs[candidate];
  const candidates = preferredCandidate
    ? [preferredCandidate]
    : [`${candidate}-icon`, candidate];

  for (const slug of candidates) {
    if (getIcon(slug)) {
      return slug;
    }
  }

  return null;
};

const getTitleIconCandidates = (title?: string | null): string[] => {
  if (!title) {
    return [];
  }

  const normalizedTitle = normalizeIconSlug(title);
  const extension = title.match(/\.([a-z0-9]+)$/i)?.[1];

  return [
    normalizedTitle,
    extension ? normalizeIconSlug(extension) : "",
    ...normalizedTitle.split("-"),
  ];
};

const getIconSlug = (lang: string, title?: string | null): string | null => {
  const normalizedLang = normalizeIconSlug(lang);
  const candidates = [
    ...getTitleIconCandidates(title),
    normalizedLang,
    preferredIconSlugs[normalizedLang],
    normalizedLang ? `${normalizedLang}-icon` : "",
  ];

  for (const candidate of candidates) {
    if (!candidate) {
      continue;
    }

    const iconSlug = getExistingIconSlug(candidate);

    if (iconSlug) {
      return iconSlug;
    }
  }

  return null;
};

const getIconSymbol = (name: string): DevIconSymbol | null => {
  const symbolMatch = spriteMarkup.match(
    new RegExp(`<symbol([^>]*\\sid="${name}"[^>]*)>([\\s\\S]*?)<\\/symbol>`)
  );

  if (!symbolMatch) {
    return null;
  }

  return {
    content: symbolMatch[2],
    viewBox: symbolMatch[1].match(/\sviewBox="([^"]+)"/)?.[1] ?? "0 0 600 600",
  };
};

const langIcon = getIconSlug(lang, title);
const codeIcon: IconRecord | undefined = langIcon
  ? getIcon(langIcon)
  : undefined;
const codeIconSymbol = codeIcon ? getIconSymbol(codeIcon.name) : null;
const codeIconLabel = langName ?? langIcon ?? lang;
---

<div class="code-header flex space-between center px-1">
  <div class="code-filename flex center gap-half">
    {
      codeIconSymbol && (
        <svg
          class="code-icon"
          role="img"
          aria-label={codeIconLabel}
          viewBox={codeIconSymbol?.viewBox ?? "0 0 600 600"}
        >
          {codeIconSymbol && <Fragment set:html={codeIconSymbol.content} />}
        </svg>
      )
    }
    {title && <span class="mono small-text lh-1">{title}</span>}
  </div>
  <div class="code-copy">
    <button class="copy-btn" data-id="cp" data-copy-btn data-code={code}>
      <span data-id="copy-icon" class="btn-holder btn-icon-copy">
        <Copy size={16} />
      </span>

      <span data-id="check-icon" class="btn-holder btn-icon-check">
        <Check size={16} />
      </span>
    </button>
  </div>
</div>
