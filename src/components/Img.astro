---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: string | ImageMetadata;
  alt?: string;
  title?: string;
  credits?: {
    username?: string;
    url?: string;
  };
}

const { src, alt, credits, title } = Astro.props;
const imageProps = {
  width: 1000,
  height: 500,
  quality: 100,
  title: title ?? "",
  decoding: "async" as const,
  loading: "lazy" as const,
  format: "jpg" as const,
  alt: alt ?? "",
};
---

<figure>
  {
    typeof src === "string" ? (
      <Image src={src} {...imageProps} />
    ) : (
      <Image src={src as ImageMetadata} {...imageProps} />
    )
  }
  {
    credits && (
      <figcaption class="small-text">Image Credits: {credits.url}</figcaption>
    )
  }
</figure>
