---
import CopyButton from "./CopyButton.svelte";

interface Props {
  heroImageGenerator?: string;
  prompt: string;
}

const { heroImageGenerator, prompt }: Props = Astro.props;
const label = heroImageGenerator
  ? `Image prompt from ${heroImageGenerator}`
  : "Image prompt";
---

<CopyButton
  client:load
  ariaLabel={label}
  fluid
  label={label}
  text={prompt}
/>
